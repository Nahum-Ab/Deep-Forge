# ==========================================
# DEEPFORGE ENVIRONMENT CONFIGURATION
# ==========================================

# 1. APP CONFIGURATION
# ------------------------------------------
# The base URL where your app is hosted (used for email templates and redirects)
# Example: https://deepforge.com or http://localhost:3000
SITE_URL=http://localhost:3000
APP_URL=http://localhost:3000

# 2. GUMROAD INTEGRATION
# ------------------------------------------
# Required to fetch products dynamically from Gumroad in /api/products
# Go to Gumroad Settings -> Advanced -> Applications and generate an access token.
GUMROAD_ACCESS_TOKEN=bVr_V9Wax81RJZ-Ek0O25_bmf-3zslMhzIFdaWo8JJ8

# 3. GOOGLE SHEETS INTEGRATION (Waitlist / Email Capture)
# ------------------------------------------
# Used silently in /api/subscribe to add waitlist/email subscribers to a Google Sheet.
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here
GOOGLE_SERVICE_ACCOUNT_EMAIL=your_service_account_email@project.iam.gserviceaccount.com
# IMPORTANT: The private key must include the BEGIN and END tags, and "\n" newlines.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour\nPrivate\nKey\nHere\n-----END PRIVATE KEY-----\n"

# 4. EMAIL DELIVERY (Welcome Emails)
# ------------------------------------------
# Choose ONE method below (Resend recommended for ease).
EMAIL_FROM="DeepForge Team <hello@deepforge.com>"

# OPTION A: RESEND (Modern)
# Get a key from resend.com
RESEND_API_KEY=re_your_resend_api_key_here

# OPTION B: SMTP / NODEMAILER (Legacy/Gmail)
# E.g., for Gmail, use an App Password.
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# 5. FIREBASE CONFIGURATION (Optional - Client side tracking/auth if used)
# ------------------------------------------
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890
